{
	"name": "@doist/outline-cli",
	"version": "1.0.0",
	"description": "CLI for the Outline wiki/knowledge base API",
	"type": "module",
	"bin": {
		"ol": "./dist/index.js"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Doist/outline-cli.git"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"homepage": "https://github.com/Doist/outline-cli#readme",
	"bugs": {
		"url": "https://github.com/Doist/outline-cli/issues"
	},
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"type-check": "tsc --noEmit",
		"format": "biome check --write",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepare": "node scripts/prepare.js",
		"postinstall": "test -f dist/postinstall.js && node dist/postinstall.js || true"
	},
	"keywords": [
		"outline",
		"wiki",
		"cli"
	],
	"license": "MIT",
	"dependencies": {
		"chalk": "5.6.2",
		"commander": "14.0.2",
		"marked": "15.0.12",
		"marked-terminal": "7.3.0",
		"open": "10.2.0",
		"yocto-spinner": "1.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.12",
		"@types/node": "25.0.10",
		"lefthook": "2.0.15",
		"typescript": "5.9.3",
		"vitest": "4.0.18"
	}
}
