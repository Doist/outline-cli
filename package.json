{
  "name": "outline-cli",
  "version": "0.1.0",
  "description": "CLI for the Outline wiki/knowledge base API",
  "type": "module",
  "bin": {
    "ol": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "format": "biome check --write",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "outline",
    "wiki",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "14.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@types/node": "25.0.10",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
